# ELN — Environment variables
# Copy to .env for Docker Compose, or to apps/backend/.env for local dev.

# ── Docker Compose (.env at repo root) ──────────────────────────────────
# PostgreSQL
DB_USER=eln
DB_PASSWORD=eln
DB_NAME=eln
DB_PORT_EXTERNAL=5432

# JWT — MUST be at least 16 characters
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost

# Port mapping
BACKEND_PORT=3000
FRONTEND_PORT=80

# ── Local development (apps/backend/.env) ───────────────────────────────
# DATABASE_URL=postgresql://eln:eln@localhost:5432/eln
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=eln
# DB_PASSWORD=eln
# DB_NAME=eln
# DB_SSL=false
# PORT=3000
# CORS_ORIGIN=http://localhost:5173

# File storage (local disk for MVP)
UPLOAD_DIR=./uploads
