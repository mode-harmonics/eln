# ELN Backend Environment Variables
# Copy this file to .env and fill in real values.

# PostgreSQL connection (use either DATABASE_URL or the individual vars)
DATABASE_URL=postgresql://eln:eln@localhost:5432/eln
DB_HOST=localhost
DB_PORT=5432
DB_USER=eln
DB_PASSWORD=eln
DB_NAME=eln
DB_SSL=false

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# File storage (local disk for MVP)
UPLOAD_DIR=./uploads
