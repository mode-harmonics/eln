{
  "name": "@eln/backend",
  "version": "0.1.0",
  "private": true,
  "description": "ELN backend API server (NestJS + TypeORM + PostgreSQL)",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "dev": "nest start --watch -- --env local",
    "dev:test": "nest start --watch -- --env test",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "typeorm:create": "typeorm-ts-node-commonjs migration:create",
    "typeorm:run": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts -- --env local",
    "typeorm:run:test": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts -- --env test",
    "typeorm:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts -- --env local",
    "typeorm:run:prod": "typeorm migration:run -d dist/data-source.js",
    "typeorm:revert:prod": "typeorm migration:revert -d dist/data-source.js",
    "seed": "ts-node src/seed.ts -- --env local",
    "seed:test": "ts-node src/seed.ts -- --env test",
    "seed:prod": "node dist/seed.js"
  },
  "dependencies": {
    "@eln/shared": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "joi": "^17.13.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.6.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "webpack-node-externals": "^3.0.0"
  }
}
