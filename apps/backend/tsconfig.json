{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "src",
    "baseUrl": "./",
    "sourceMap": true,
    "inlineSources": true,
    "paths": {
      "@eln/shared": ["../../packages/shared/dist"],
      "@eln/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist"]
}
