{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",

    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "incremental": true,
    "sourceMap": true,
    "inlineSources": true,
    "paths": {
      "@eln/shared": ["../../packages/shared/dist"],
      "@eln/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*", "data-source.ts"],
  "exclude": ["node_modules", "test", "dist"]
}
