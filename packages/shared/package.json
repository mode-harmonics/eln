{
  "name": "@eln/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./colors": {
      "import": "./dist/esm/colors.js",
      "require": "./dist/colors.js"
    },
    "./enums": {
      "import": "./dist/esm/enums.js",
      "require": "./dist/enums.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "dev": "tsc -p tsconfig.cjs.json --watch",
    "lint": "echo 'no lint configured'",
    "type-check": "tsc -p tsconfig.cjs.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
